# ============================================================
# Deployment Environment Variables
#
# Copy this to deploy/.env and adjust values.
# docker compose reads .env automatically.
# ============================================================

# -- Dagster metadata Postgres --
# Set these to use your own Postgres instance for Dagster metadata.
# Remove the dagster-postgres service from docker-compose.yml if
# you're using an external instance.
DAGSTER_PG_HOST=dagster-postgres
DAGSTER_PG_PORT=5432
DAGSTER_PG_DB=dagster
DAGSTER_PG_USER=dagster
DAGSTER_PG_PASSWORD=dagster

# -- Pipeline data Postgres --
# Where your pipeline assets write data.
POSTGRES_HOST=pipeline-postgres
POSTGRES_PORT=5432
POSTGRES_DB=ods
POSTGRES_USER=ods
POSTGRES_PASSWORD=demo_password

# -- Exposed ports --
DAGSTER_UI_PORT=3000
DAGSTER_PG_EXPOSE=5433
POSTGRES_EXPOSE=7432

# -- API --
API_BASE_URL=http://mock-api:8000
